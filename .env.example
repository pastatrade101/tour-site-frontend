# Frontend env — copy to .env. Only PUBLIC_* vars reach the browser.

# Backend API base URL (with /api). Leave blank for same-domain (auto-uses /api).
PUBLIC_API_URL=http://localhost:5000/api

# Public site origin for canonical URLs, OG tags, sitemap and robots.
PUBLIC_SITE_URL=http://localhost:5173

# GA4 Measurement ID (e.g. G-XXXXXXXXXX). Set to load gtag on the public site so
# analytics events also reach GA4. Leave blank to keep first-party tracking only.
# NOTE: add a cookie-consent banner before enabling this for EU visitors.
PUBLIC_GA4_MEASUREMENT_ID=
